{
  "name": "tdr-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tinacms build && react-router build",
    "dev": "cross-env TINA_PUBLIC_IS_LOCAL=true tinacms dev -c \"react-router dev\"",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
