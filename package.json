    "@tailwindcss/vite": "^4.2.1",
    "@tinacms/cli": "^2.1.11",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-cjs-interop": "^2.4.4",
    "vite-tsconfig-paths": "^5.1.4"
